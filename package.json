{
  "name": "paynest",
  "private": true,
  "version": "1.0.0",
  "description": "One nest for every payment you owe — manage payment methods, autopay every bill, and get AI-powered insight into your cash flow.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
